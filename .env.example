# Environment variables — copy to `.env` for local development

# PostgreSQL (local: docker compose up -d, then use this URL)
DATABASE_URL="postgresql://consignment:consignment@localhost:5432/consignment"

# NextAuth — generate secret: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-random-secret"

# Stripe — https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Shop name shown in the UI
NEXT_PUBLIC_SHOP_NAME="My Consignment Shop"

# Photo storage — required on Render (free tier: https://cloudinary.com)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Email (optional locally — logs to console when SMTP is unset)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Seed (optional — production seed via Render shell)
# SEED_MODE=production
# OWNER_INITIAL_PASSWORD="choose-a-strong-password"
